## AI-Assisted

## This repo has no debian/control by design (Qubes template). Tell
## genmkfile to derive the version from the nearest git tag rather
## than parsing debian/changelog, so `genmkfile git-verify` works
## here. See genmkfile/usr/share/genmkfile/shared.bsh and
## make-helper-one.bsh make_get_variables.
make_use_git_describe_for_version=true
